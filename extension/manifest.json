{
  "manifest_version": 3,
  "name": "Saturday Browser Guard",
  "description": "Checks visited URLs with the local Saturday risk engine and redirects suspicious sites to a runner-mode warning.",
  "version": "0.1.0",
  "permissions": ["webNavigation", "tabs", "storage"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:8765/*", "http://localhost:8765/*"],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_title": "Saturday",
    "default_popup": "popup.html"
  }
}
